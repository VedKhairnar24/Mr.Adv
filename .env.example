# ============================================================================
# Mr.Adv - Advocate Intelligence Platform
# Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to Git!
# ============================================================================

# =========================================
# Server Configuration
# =========================================
PORT=5000
NODE_ENV=development  # development, production
ENABLE_SCHEDULERS=true  # Set to false to disable background schedulers

# =========================================
# JWT Authentication
# =========================================
# Change this to a random secure string in production
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d  # Token expiration time

# =========================================
# Database Configuration
# =========================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=advocate_case_db
DB_PORT=3306

# =========================================
# Redis Configuration (Required for notifications & queue)
# =========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # Leave empty if no password
REDIS_DB=0

# =========================================
# OpenRouter AI Configuration
# =========================================
# Get your API key from: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-YOUR_ACTUAL_KEY_HERE
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# =========================================
# Email Configuration (Optional - for notifications)
# =========================================
# Leave empty to disable email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false  # true for port 465, false for other ports
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

EMAIL_FROM=noreply@advocate.com
EMAIL_FROM_NAME=Advocate Intelligence Platform

# =========================================
# Logging Configuration
# =========================================
LOG_LEVEL=info  # error, warn, info, debug

# =========================================
# File Upload Configuration
# =========================================
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,mp3,mp4

# =========================================
# Security Configuration
# =========================================
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window

# CORS
CORS_ORIGIN=http://localhost:5173  # Frontend URL

# =========================================
# Optional: Cloud Storage (Future)
# =========================================
# AWS_S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1

