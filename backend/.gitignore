# ===========================================
# Backend - Node.js Git Ignore File
# Mr.Adv Backend API
# ===========================================

# DEPENDENCIES (NEVER commit - too large)
node_modules/
**/node_modules/
bower_components/

# ENVIRONMENT VARIABLES (SECURITY - contains secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# LOGS AND DEBUG FILES (clutter Git history)
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# RUNTIME DATA (changes constantly)
pids/
*.pid
*.seed
*.pid.lock
lib-cov/

# TEST COVERAGE (generated by Jest/testing)
coverage/
.nyc_output/
jest-cache/

# BUILD OUTPUTS (can be regenerated)
dist/
build/
out/
.next/
.cache/

# IDE AND EDITOR FILES (personal settings)
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
Thumbs.db
ehthumbs.db

# OS GENERATED FILES
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# UPLOADS DIRECTORY (user-generated files)
uploads/*
!uploads/.gitkeep
uploads/documents/*
!uploads/documents/.gitkeep
uploads/evidence/*
!uploads/evidence/.gitkeep

# DATABASE FILES (if using local SQLite)
*.db
*.sqlite
*.sqlite3

# TEMPORARY FILES
tmp/
temp/
*.tmp
*.temp

# MISCELLANEOUS (security/misc)
*.pem
*.key
*.crt
*.cer
*.der

# PACKAGE MANAGER CACHE
.eslintcache
.stylelintcache

# OPTIONAL - Choose dependency lock strategy
# Uncomment if you want to ignore (not recommended for production):
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ===========================================
# WHAT TO COMMIT (Backend):
# ✅ Source code (.js, .jsx, .ts, .tsx)
# ✅ Configuration templates (.env.example)
# ✅ Database schemas (.sql)
# ✅ Documentation (.md)
# ✅ package.json (dependencies list)
# ✅ .gitignore (this file)
# ✅ server.js and all controllers/routes
# ===========================================
